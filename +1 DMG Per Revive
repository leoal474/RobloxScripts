local flags = {KillAura = false, AutoAttack = false}

local function createToggle(text, pos, callback)
    local btn = Instance.new("TextButton", MainFrame)
    btn.Size = UDim2.new(0.9, 0, 0, 35)
    btn.Position = pos
    btn.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
    btn.Font = Enum.Font.SourceSansBold
    btn.Text = text .. ": OFF"
    btn.TextColor3 = Color3.fromRGB(200, 200, 200)
    btn.TextSize = 14
    btn.BorderSizePixel = 0
    
    local active = false
    btn.MouseButton1Click:Connect(function()
        active = not active
        btn.BackgroundColor3 = active and Color3.fromRGB(60, 160, 60) or Color3.fromRGB(45, 45, 50)
        btn.Text = text .. (active and ": ON" or ": OFF")
        btn.TextColor3 = active and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(200, 200, 200)
        callback(active)
    end)
    return btn
end

createToggle("Aimbot / Kill Aura", UDim2.new(0.05, 0, 0.28, 0), function(val) flags.KillAura = val end)
createToggle("Auto Attack", UDim2.new(0.05, 0, 0.60, 0), function(val) flags.AutoAttack = val end)

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local VirtualUser = game:GetService("VirtualUser")

local function getClosestPlayer()
    local closest = nil
    local maxDist = 25 -- Saldırı mesafesi (Menzil)
    local pChar = LocalPlayer.Character
    if not pChar or not pChar:FindFirstChild("HumanoidRootPart") then return nil end
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character:FindFirstChild("Humanoid") then
            if player.Character.Humanoid.Health > 0 then
                local dist = (pChar.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude
                if dist < maxDist then
                    maxDist = dist
                    closest = player.Character.HumanoidRootPart
                end
            end
        end
    end
    return closest
end

task.spawn(function()
    while true do
        task.wait(0.05)
        local target = getClosestPlayer()
        if target and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            -- Aimbot / Kill Aura: Kamerayı ve karakteri anında en yakındaki düşmana kilitler
            if flags.KillAura then
                workspace.CurrentCamera.CFrame = CFrame.new(workspace.CurrentCamera.CFrame.Position, target.Position)
                LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(LocalPlayer.Character.HumanoidRootPart.Position, Vector3.new(target.Position.X, LocalPlayer.Character.HumanoidRootPart.Position.Y, target.Position.Z))
            end
            -- Auto Attack: Düşman menzile girdiğinde otomatik sol tık basar (Kılıç sallama/Vurma)
            if flags.AutoAttack then
                VirtualUser:CaptureController()
                VirtualUser:ClickButton1(Vector2.new(850, 520))
            end
        end
    end
end)
