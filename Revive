local ReplicatedStorage = game:GetService("ReplicatedStorage")
local found = false

for _, v in pairs(ReplicatedStorage:GetDescendants()) do
    if v.Name:lower():find("attack") or v.Name:lower():find("reaper") then
        print("BULUNDU: " .. v.Name .. " - " .. v:GetFullName())
        found = true
    end
end

if not found then
    print("HATA: Oyun içinde 'Attack' veya 'Reaper' isminde hiçbir şey bulunamadı!")
else
    print("Başarılı: Bazı remote'lar bulundu, kodun ismini güncellememiz gerekiyor.")
end
