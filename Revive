local Player = game:GetService("Players").LocalPlayer

-- Kill Aura (Fiziksel temasla öldürme)
local function startKillAura()
    while true do
        task.wait(0.2)
        local char = Player.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("Humanoid") and v.Health > 0 and v.Parent ~= char then
                    local targetRoot = v.Parent:FindFirstChild("HumanoidRootPart")
                    if targetRoot and (targetRoot.Position - char.HumanoidRootPart.Position).Magnitude < 15 then
                        -- Fiziksel temas (Remote kullanmıyoruz)
                        v.Health = 0 
                    end
                end
            end
        end
    end
end

-- Revive/Reaper için alternatif fiziksel dokunuş
task.spawn(startKillAura)
