local Player = game:GetService("Players").LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- Oyunun içindeki tüm klasörleri tarayıp doğru olanı bulur
local function findRemote(name)
    for _, folder in pairs(ReplicatedStorage:GetChildren()) do
        if folder:IsA("Folder") or folder:IsA("RemoteEvent") then
            local target = folder:FindFirstChild(name)
            if target then return target end
        end
    end
    return nil
end

-- 20 Saniyede bir Reaper
task.spawn(function()
    while true do
        local reaper = findRemote("Reaper") or findRemote("Revive")
        if reaper then reaper:FireServer() end
        task.wait(20)
    end
end)

