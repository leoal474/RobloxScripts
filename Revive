local Player = game:GetService("Players").LocalPlayer
local Remotes = game:GetService("ReplicatedStorage"):FindFirstChild("Remotes")

-- 20 Saniyede bir Reaper
task.spawn(function()
    while true do
        if Remotes and Remotes:FindFirstChild("Reaper") then
            Remotes.Reaper:FireServer()
        end
        task.wait(20)
    end
end)

-- Sürekli Saldırı
task.spawn(function()
    while true do
        task.wait(0.1)
        if Remotes and Remotes:FindFirstChild("Attack") then
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("Humanoid") and v.Health > 0 and v.Parent ~= Player.Character then
                    Remotes.Attack:FireServer(v.Parent)
                end
            end
        end
    end
end)
