-- Advanced Auto Engine with Waiting System
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Player = Players.LocalPlayer

local function getRemote(name)
    local RemoteFolder = ReplicatedStorage:FindFirstChild("Remotes") or ReplicatedStorage:FindFirstChild("Events")
    if RemoteFolder then
        for _, v in pairs(RemoteFolder:GetChildren()) do
            if v.Name:lower():find(name:lower()) then return v end
        end
    end
    return nil
end

-- Reaper Loop
task.spawn(function()
    while true do
        local reaper = getRemote("reaper") or getRemote("revive")
        if reaper then
            reaper:FireServer()
        end
        task.wait(20)
    end
end)

