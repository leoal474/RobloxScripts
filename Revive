    MainFrame.Visible = false
    OpenBtn.Visible = true
end)

OpenBtn.MouseButton1Click:Connect(function()
    MainFrame.Visible = true
    OpenBtn.Visible = false
end)

local flags = {KillAll = false, AutoReaper = false}

local function createToggle(text, pos, callback)
    local btn = Instance.new("TextButton", MainFrame)
    btn.Size = UDim2.new(0.9, 0, 0, 40)
    btn.Position = pos
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
    btn.Text = text .. ": OFF"
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Parent = MainFrame
    local active = false
    btn.MouseButton1Click:Connect(function()
        active = not active
        btn.BackgroundColor3 = active and Color3.fromRGB(60, 160, 60) or Color3.fromRGB(40, 40, 45)
        btn.Text = text .. (active and ": ON" or ": OFF")
        callback(active)
    end)
end

createToggle("Kill All", UDim2.new(0.05, 0, 0.2, 0), function(val) flags.KillAll = val end)
createToggle("Auto Reaper", UDim2.new(0.05, 0, 0.4, 0), function(val) flags.AutoReaper = val end)

task.spawn(function()
    while true do task.wait(20)
        if flags.AutoReaper then
            local rem = game:GetService("ReplicatedStorage"):FindFirstChild("Remotes")
            if rem and rem:FindFirstChild("Reaper") then rem.Reaper:FireServer() end
        end
    end
end)

task.spawn(function()
    while true do task.wait(0.2)
        if flags.KillAll then
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("Humanoid") and v.Health > 0 and v.Parent ~= game.Players.LocalPlayer.Character then
                    local rem = game:GetService("ReplicatedStorage"):FindFirstChild("Remotes")
                    if rem and rem:FindFirstChild("Attack") then rem.Attack:FireServer(v.Parent) end
                end
            end
        end
    end
end)
