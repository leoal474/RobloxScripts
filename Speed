local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- Speed Functionality
local function updateSpeed(value)
    flags.SpeedValue = value
    flags.SpeedToggle = true
end

Btn50.MouseButton1Click:Connect(function() updateSpeed(50) end)
Btn150.MouseButton1Click:Connect(function() updateSpeed(150) end)
Btn300.MouseButton1Click:Connect(function() updateSpeed(300) end)

task.spawn(function()
    while true do
        task.wait(0.1)
        if flags.SpeedToggle then
            local char = LocalPlayer.Character
            if char and char:FindFirstChild("Humanoid") then
                char.Humanoid.WalkSpeed = flags.SpeedValue
            end
        end
    end
end)

-- Perfect ESP Functionality (Highlights players through walls)
local function applyESP(player)
    if player ~= LocalPlayer and player.Character then
        if not player.Character:FindFirstChild("ESPHighlight") then
            local highlight = Instance.new("Highlight")
            highlight.Name = "ESPHighlight"
            highlight.FillColor = Color3.fromRGB(255, 0, 150)
            highlight.FillTransparency = 0.5
            highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
            highlight.OutlineTransparency = 0
            highlight.Adornee = player.Character
            highlight.Parent = player.Character
        end
    end
end

local function removeESP()
    for _, player in pairs(Players:GetPlayers()) do
        if player.Character and player.Character:FindFirstChild("ESPHighlight") then
            player.Character.ESPHighlight:Destroy()
        end
    end
end

ESPBtn.MouseButton1Click:Connect(function()
    flags.ESP = not flags.ESP
    ESPBtn.BackgroundColor3 = flags.ESP and Color3.fromRGB(60, 160, 60) or Color3.fromRGB(45, 45, 50)
    ESPBtn.Text = flags.ESP and "Player ESP: ON" or "Player ESP: OFF"
    ESPBtn.TextColor3 = flags.ESP and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(200, 200, 200)
end)

task.spawn(function()
    while true do
        task.wait(1)
        if flags.ESP then
            for _, player in pairs(Players:GetPlayers()) do
                applyESP(player)
            end
        else
            removeESP()
        end
    end
end)
