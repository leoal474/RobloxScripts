local Player = game:GetService("Players").LocalPlayer
local Character = Player.Character or Player.CharacterAdded:Wait()
local Humanoid = Character:WaitForChild("Humanoid")

-- Hız ayarları (Kasma ve takılma yapmaz)
local speeds = {50, 100, 200, 250, 300, 400}

-- Delta için basit bir menü
local library = {
    ["Speed"] = 16 -- Başlangıç hızı
}

-- Hızı sabitleyen ve takılmayı önleyen fonksiyon
local function setSpeed(s)
    library.Speed = s
    Humanoid.WalkSpeed = s
end

-- Delta Menüsü (Sadece Hız Butonları)
local OrionLib = loadstring(game:HttpGet("https://raw.githubusercontent.com/shlexware/Orion/main/source"))()
local Window = OrionLib:MakeWindow({Name = "Candy Speed Hack", HidePremium = true, SaveConfig = true})
local Tab = Window:MakeTab({Name = "Hız Menüsü", Icon = "rbxassetid://4483345998", PremiumOnly = false})

for _, s in pairs(speeds) do
    Tab:AddButton({
        Name = "Hız: " .. s,
        Callback = function()
            setSpeed(s)
        end    
    })
end

Tab:AddButton({
    Name = "Hızı Sıfırla (16)",
    Callback = function()
        setSpeed(16)
    end    
})

OrionLib:Init()
