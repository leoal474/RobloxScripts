local flags = {ESP = false, SpeedToggle = false, SpeedValue = 16}

-- Buton Oluşturucu Fonksiyon
local function createSpeedBtn(text, pos, value)
    local btn = Instance.new("TextButton", MainFrame)
    btn.Size = UDim2.new(0.9, 0, 0, 35)
    btn.Position = pos
    btn.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
    btn.Font = Enum.Font.SourceSansBold
    btn.Text = "Speed: " .. text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.BorderSizePixel = 0
    
    btn.MouseButton1Click:Connect(function()
        flags.SpeedValue = value
        flags.SpeedToggle = true
        -- Görsel geri bildirim
        for _, child in pairs(MainFrame:GetChildren()) do
            if child:IsA("TextButton") and child ~= CloseBtn and string.find(child.Text, "Speed:") then
                child.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
            end
        end
        btn.BackgroundColor3 = Color3.fromRGB(60, 160, 60)
    end)
    return btn
end

-- İstediğin Hız Seçenekleri
createSpeedBtn("50", UDim2.new(0.05, 0, 0.15, 0), 50)
createSpeedBtn("100", UDim2.new(0.05, 0, 0.30, 0), 100)
createSpeedBtn("200", UDim2.new(0.05, 0, 0.45, 0), 200)
createSpeedBtn("300 (God)", UDim2.new(0.05, 0, 0.60, 0), 300)

-- ESP Butonu
local ESPBtn = Instance.new("TextButton", MainFrame)
ESPBtn.Size = UDim2.new(0.9, 0, 0, 35)
ESPBtn.Position = UDim2.new(0.05, 0, 0.80, 0)
ESPBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
ESPBtn.Font = Enum.Font.SourceSansBold
ESPBtn.Text = "Player ESP: OFF"
ESPBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
ESPBtn.BorderSizePixel = 0

-- Saniyede 60+ kez hızı kontrol eden kesintisiz motor (RunService)
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

RunService.RenderStepped:Connect(function()
    if flags.SpeedToggle then
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("Humanoid") then
            char.Humanoid.WalkSpeed = flags.SpeedValue
        end
    end
end)

-- ESP Fonksiyonları
local function applyESP(player)
    if player ~= LocalPlayer and player.Character then
        if not player.Character:FindFirstChild("ESPHighlight") then
            local highlight = Instance.new("Highlight")
            highlight.Name = "ESPHighlight"
            highlight.FillColor = Color3.fromRGB(255, 0, 150)
            highlight.FillTransparency = 0.5
            highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
            highlight.OutlineTransparency = 0
            highlight.Adornee = player.Character
            highlight.Parent = player.Character
        end
    end
end

local function removeESP()
    for _, player in pairs(Players:GetPlayers()) do
        if player.Character and player.Character:FindFirstChild("ESPHighlight") then
            player.Character.ESPHighlight:Destroy()
        end
    end
end

ESPBtn.MouseButton1Click:Connect(function()
    flags.ESP = not flags.ESP
    ESPBtn.BackgroundColor3 = flags.ESP and Color3.fromRGB(60, 160, 60) or Color3.fromRGB(45, 45, 50)
    ESPBtn.Text = flags.ESP and "Player ESP: ON" or "Player ESP: OFF"
    ESPBtn.TextColor3 = flags.ESP and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(200, 200, 200)
end)

task.spawn(function()
    while true do
        task.wait(1)
        if flags.ESP then
            for _, player in pairs(Players:GetPlayers()) do
                applyESP(player)
            end
        else
            removeESP()
        end
    end
end)
