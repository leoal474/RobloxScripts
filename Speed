local Player = game:GetService("Players").LocalPlayer
local Character = Player.Character or Player.CharacterAdded:Wait()
local Humanoid = Character:WaitForChild("Humanoid")

-- Buradan hızını istediğin gibi (150, 250 veya 350) değiştir:
local ISTENEN_HIZ = 250 

Humanoid.WalkSpeed = ISTENEN_HIZ

-- Karakter sıfırlanırsa hızın gitmemesi için
Player.CharacterAdded:Connect(function(char)
    task.wait(0.5)
    char:WaitForChild("Humanoid").WalkSpeed = ISTENEN_HIZ
end)

