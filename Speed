local Player = game:GetService("Players").LocalPlayer
local UIS = game:GetService("UserInputService")

-- Sadece Hız - Menüsüz, Engellenemez
local function setSpeed(s)
    if Player.Character and Player.Character:FindFirstChild("Humanoid") then
        Player.Character.Humanoid.WalkSpeed = s
    end
end

-- Klavye ile Hız Değiştirme (Takılma yapmaz)
UIS.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == Enum.KeyCode.One then setSpeed(150)
    elseif input.KeyCode == Enum.KeyCode.Two then setSpeed(250)
    elseif input.KeyCode == Enum.KeyCode.Three then setSpeed(350)
    elseif input.KeyCode == Enum.KeyCode.Four then setSpeed(16) end
end)

print("Hız scripti yüklendi! 1=150, 2=250, 3=350, 4=Normal")
